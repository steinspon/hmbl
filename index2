<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Himmelblå</title>

  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="Himmelblå">
  <link id="apple-touch-icon" rel="apple-touch-icon" href="logo.png">
  <link id="favicon-icon" rel="icon" href="logo.png">

  <style>
    :root {
      --bg: #eef4fb;
      --bg-top-glow: rgba(70,142,226,0.22);
      --bg-grad-top: #f6fbff;
      --bg-grad-bottom: #eaf2fb;

      --shell-top: rgba(255,255,255,0.74);
      --shell-bottom: rgba(255,255,255,0.88);
      --shell-border: rgba(255,255,255,0.7);
      --shell-shadow: 0 18px 40px rgba(17,38,68,0.14);

      --hero-top: rgba(255,255,255,0.52);
      --hero-bottom: rgba(255,255,255,0.18);

      --card: rgba(255,255,255,0.82);
      --card-strong: rgba(255,255,255,0.92);
      --text: #10233f;
      --muted: #516784;
      --border: rgba(16,35,63,0.10);
      --shadow: 0 12px 32px rgba(16,35,63,0.12);
      --accent: #143b73;
      --accent-2: #2457a6;
      --accent-soft: rgba(36,87,166,0.10);

      --logo-bg: white;
      --logo-shadow: 0 8px 24px rgba(16,35,63,0.10);

      --tool-border: rgba(20,59,115,0.10);
      --tool-active-top: rgba(255,255,255,0.96);
      --tool-active-bottom: rgba(241,247,255,0.96);
      --tool-active-shadow: 0 8px 18px rgba(16,35,63,0.12);

      --radius-xl: 24px;
      --radius-lg: 18px;
      --radius-md: 14px;
      --safe-top: env(safe-area-inset-top, 0px);
      --safe-bottom: env(safe-area-inset-bottom, 0px);
    }

    html[data-theme="dark"] {
      --bg: #0a1220;
      --bg-top-glow: rgba(80, 220, 170, 0.16);
      --bg-grad-top: #0f1b2b;
      --bg-grad-bottom: #09111d;

      --shell-top: rgba(17,27,42,0.82);
      --shell-bottom: rgba(14,22,35,0.90);
      --shell-border: rgba(130,170,220,0.10);
      --shell-shadow: 0 18px 40px rgba(0,0,0,0.34);

      --hero-top: rgba(255,255,255,0.04);
      --hero-bottom: rgba(255,255,255,0.02);

      --card: rgba(20,31,48,0.84);
      --card-strong: rgba(24,37,56,0.92);
      --text: #e7eef8;
      --muted: #9fb0c7;
      --border: rgba(170,190,220,0.10);
      --shadow: 0 12px 32px rgba(0,0,0,0.28);
      --accent: #6de3b0;
      --accent-2: #4eb7ff;
      --accent-soft: rgba(109,227,176,0.10);

      --logo-bg: rgba(255,255,255,0.03);
      --logo-shadow: 0 8px 24px rgba(0,0,0,0.25);

      --tool-border: rgba(109,227,176,0.12);
      --tool-active-top: rgba(32,45,64,0.98);
      --tool-active-bottom: rgba(25,37,54,0.98);
      --tool-active-shadow: 0 8px 18px rgba(0,0,0,0.24);
    }

    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    html, body {
      margin: 0;
      padding: 0;
      min-height: 100%;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top, var(--bg-top-glow), transparent 38%),
        linear-gradient(180deg, var(--bg-grad-top) 0%, var(--bg-grad-bottom) 100%);
      transition:
        background 0.35s ease,
        color 0.35s ease;
    }

    body {
      display: flex;
      justify-content: center;
    }

    .app {
      width: 100%;
      max-width: 520px;
      min-height: 100vh;
      padding: calc(14px + var(--safe-top)) 14px calc(24px + var(--safe-bottom));
    }

    .shell {
      background: linear-gradient(180deg, var(--shell-top), var(--shell-bottom));
      border: 1px solid var(--shell-border);
      border-radius: 28px;
      box-shadow: var(--shell-shadow);
      overflow: hidden;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      transition:
        background 0.35s ease,
        border-color 0.35s ease,
        box-shadow 0.35s ease;
    }

    .hero {
      padding: 16px 16px 10px;
      border-bottom: 1px solid var(--border);
      background: linear-gradient(180deg, var(--hero-top), var(--hero-bottom));
      transition:
        background 0.35s ease,
        border-color 0.35s ease;
    }

    .logo-wrap {
      width: 100%;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .logo {
      width: 100%;
      max-width: 100%;
      display: block;
      border-radius: 22px;
      object-fit: contain;
      background: var(--logo-bg);
      box-shadow: var(--logo-shadow);
      transition:
        background 0.35s ease,
        box-shadow 0.35s ease;
    }

    .header {
      padding: 18px 18px 6px;
      text-align: center;
    }

    .title {
      margin: 0;
      font-size: 1.85rem;
      line-height: 1.05;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: var(--text);
    }

    .subtitle {
      margin: 10px 0 0;
      font-size: 0.98rem;
      line-height: 1.4;
      color: var(--muted);
    }

    .section {
      padding: 12px 14px 18px;
    }

    .section-label {
      margin: 0 4px 12px;
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .tool-list {
      display: grid;
      gap: 12px;
    }

    .tool-button {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      width: 100%;
      padding: 18px 18px;
      border: 1px solid var(--tool-border);
      border-radius: var(--radius-lg);
      background: linear-gradient(180deg, var(--card-strong), var(--card));
      color: var(--text);
      text-decoration: none;
      box-shadow: var(--shadow);
      transition:
        transform 0.15s ease,
        box-shadow 0.15s ease,
        background 0.15s ease,
        border-color 0.35s ease,
        color 0.35s ease;
    }

    .tool-button:active {
      transform: scale(0.985);
      box-shadow: var(--tool-active-shadow);
      background: linear-gradient(180deg, var(--tool-active-top), var(--tool-active-bottom));
    }

    .tool-left {
      display: flex;
      align-items: center;
      gap: 14px;
      min-width: 0;
    }

    .tool-icon {
      width: 48px;
      height: 48px;
      border-radius: 14px;
      display: grid;
      place-items: center;
      background: linear-gradient(180deg, var(--accent), var(--accent-2));
      color: white;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.18);
      flex: 0 0 auto;
      transition: background 0.35s ease;
    }

    .tool-text {
      min-width: 0;
      text-align: left;
    }

    .tool-title {
      display: block;
      font-size: 1.02rem;
      font-weight: 750;
      line-height: 1.2;
      color: var(--text);
    }

    .tool-desc {
      display: block;
      margin-top: 4px;
      font-size: 0.92rem;
      line-height: 1.35;
      color: var(--muted);
    }

    .chevron {
      color: var(--accent);
      flex: 0 0 auto;
      opacity: 0.9;
      transition: color 0.35s ease;
    }

    .footer-note {
      margin: 14px 4px 0;
      font-size: 0.86rem;
      line-height: 1.4;
      color: var(--muted);
      text-align: center;
    }

    @media (min-width: 520px) {
      .app { padding-left: 18px; padding-right: 18px; }
      .hero { padding: 18px 18px 10px; }
      .header { padding: 20px 22px 8px; }
      .section { padding: 14px 18px 22px; }
    }
  </style>
</head>
<body>
  <main class="app">
    <div class="shell">
      <section class="hero">
        <div class="logo-wrap">
          <img id="main-logo" src="logo.png" alt="Himmelblå logo" class="logo">
        </div>
      </section>

      <header class="header">
      </header>

      <section class="section">
        <div class="tool-list">
          <a class="tool-button" href="rigdown.html" aria-label="Rig-down checklist">
            <div class="tool-left">
              <div class="tool-icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M9 12.5L11.2 14.7L15.5 9.8" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M7 4.5H17C18.1046 4.5 19 5.39543 19 6.5V19.5L16 17.2L13 19.5L10 17.2L7 19.5V6.5C7 5.39543 7.89543 4.5 9 4.5Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="tool-text">
                <span class="tool-title">Rig-down checklist</span>
                <span class="tool-desc">Shutdown and departure checklist for the cabin.</span>
              </div>
            </div>
            <svg class="chevron" width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M9 5L16 12L9 19" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>

          <a class="tool-button" href="contacts.html" aria-label="Open Contacts">
            <div class="tool-left">
              <div class="tool-icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M6.5 4.5H17.5C18.3284 4.5 19 5.17157 19 6V18C19 18.8284 18.3284 19.5 17.5 19.5H6.5C5.67157 19.5 5 18.8284 5 18V6C5 5.17157 5.67157 4.5 6.5 4.5Z" stroke="currentColor" stroke-width="2"/>
                  <path d="M9 10C9 8.89543 9.89543 8 11 8H13C14.1046 8 15 8.89543 15 10C15 11.1046 14.1046 12 13 12H11C9.89543 12 9 11.1046 9 10Z" stroke="currentColor" stroke-width="2"/>
                  <path d="M8 16C8.8 14.8 10.2 14 12 14C13.8 14 15.2 14.8 16 16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="tool-text">
                <span class="tool-title">Contacts</span>
                <span class="tool-desc">Useful contacts related to the cabin.</span>
              </div>
            </div>
            <svg class="chevron" width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M9 5L16 12L9 19" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>

          <a class="tool-button" href="specs.html" aria-label="Open Specs">
            <div class="tool-left">
              <div class="tool-icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8 4.5H13.5L17 8V18.5C17 19.0523 16.5523 19.5 16 19.5H8C7.44772 19.5 7 19.0523 7 18.5V5.5C7 4.94772 7.44772 4.5 8 4.5Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                  <path d="M13 4.5V8H16.5" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                  <path d="M9.5 11H14.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <path d="M9.5 14H14.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <path d="M9.5 17H12.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="tool-text">
                <span class="tool-title">Technical</span>
                <span class="tool-desc">Device specifications and User Manuals.</span>
              </div>
            </div>
            <svg class="chevron" width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M9 5L16 12L9 19" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </section>
    </div>
  </main>

  <script>
    (function () {
      const DARK_HOUR_START = 19;

      const logo = document.getElementById("main-logo");
      const favicon = document.getElementById("favicon-icon");
      const appleTouchIcon = document.getElementById("apple-touch-icon");

      function getThemeByTime() {
        const now = new Date();
        const hour = now.getHours();
        return hour >= DARK_HOUR_START ? "dark" : "light";
      }

      function applyTheme() {
        const theme = getThemeByTime();
        document.documentElement.setAttribute("data-theme", theme);

        const logoPath = theme === "dark" ? "logo-night.png" : "logo.png";

        if (logo) logo.src = logoPath;
        if (favicon) favicon.href = logoPath;
        if (appleTouchIcon) appleTouchIcon.href = logoPath;
      }

      applyTheme();

      setInterval(applyTheme, 60000);
    })();
  </script>
</body>
</html>
